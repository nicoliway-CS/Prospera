# Copy this file to ".env" and fill in your real values.
# ".env" is gitignored — never commit your tokens.

PROSPERA_BASE_URL="https://staging-portal.eprospera.com"

# Personal user token (sk-...): authenticates you against /me endpoints.
PROSPERA_API_TOKEN="sk-your-token-here"

# Agent token (ak-...): used by the scope-probe / agent-scoped endpoints.
PROSPERA_AGENT_TOKEN="ak-your-token-here"
